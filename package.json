{
  "name": "openclaw-feishu-fix",
  "version": "0.1.0",
  "description": "Reusable fixer for OpenClaw Feishu media sending and API call pressure issues",
  "type": "module",
  "private": false,
  "keywords": [
    "openclaw",
    "feishu",
    "diagnostics",
    "agents",
    "cli"
  ],
  "bin": {
    "openclaw-feishu-fix": "./bin/openclaw-feishu-fix.js"
  },
  "scripts": {
